# Copy to .env on the Synology NAS and fill real values there.
# Never commit .env.

# LiteLLM admin/master key. Must start with sk-.
LITELLM_MASTER_KEY=sk-change-me

# Cannot be changed after adding encrypted model credentials.
# Generate a long random value and keep it backed up.
LITELLM_SALT_KEY=sk-change-me-too

# Postgres. Keep this in sync with docker-compose.yml and litellm.config.yaml.
POSTGRES_DB=litellm
POSTGRES_USER=llmproxy
POSTGRES_PASSWORD=change-me-db-password
DATABASE_URL=postgresql://llmproxy:change-me-db-password@postgres:5432/litellm

# Redis cache/auth state.
REDIS_PASSWORD=change-me-redis-password
REDIS_URL=redis://:change-me-redis-password@redis:6379/0

# Provider keys. Set only what you use.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE=https://api.deepseek.com
OPENROUTER_API_KEY=
GEMINI_API_KEY=
OPENCODE_GO_API_KEY=
OPENCODE_GO_API_BASE=https://opencode.ai/zen/go/v1
OLLAMA_API_KEY=
GATEWAY_API_KEY=

# Ollama endpoint. For Ollama Cloud use https://ollama.com/api. For local
# Ollama on another host, use its LAN or Tailscale address, for example
# http://100.x.y.z:11434.
OLLAMA_API_BASE=http://host.docker.internal:11434

# Optional hardening.
NO_DOCS=False
NO_REDOC=False
LITELLM_LOG=INFO
